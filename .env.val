# Environment VAL - Hetzner Server
NODE_ENV=validation

# Database VAL
DATABASE_URL="mysql://weekook_val_user:ValPassword123!@localhost:3306/weekook_VAL"

# Server Configuration
PORT=5173
FRONTEND_PORT=5174

# JWT Configuration
JWT_SECRET=val_weekook_jwt_secret_2024_secure_key
JWT_EXPIRES_IN=7d

# Application URL (à remplacer par l'IP ou domaine réel)
APP_URL=http://your-hetzner-server-ip:5174
API_URL=http://your-hetzner-server-ip:5173

# CORS Origins
CORS_ORIGINS=http://localhost:5174,http://your-hetzner-server-ip:5174

# Email Configuration (optionnel)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@weekook.com
# SMTP_PASS=your_smtp_password

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=val_session_secret_key_2024